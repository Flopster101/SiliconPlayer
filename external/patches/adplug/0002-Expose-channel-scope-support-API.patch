diff --git a/src/adlibemu.c b/src/adlibemu.c
index 4f1277a..a5efa08 100644
--- a/src/adlibemu.c
+++ b/src/adlibemu.c
@@ -440,7 +440,12 @@ void adlibsetvolume(adlibemu_context *ctx,int i) {
     AMPSCALE=i;
 }
 
-void adlibgetsample (adlibemu_context *ctx, unsigned char *sndptr, long numbytes)
+void adlibgetsample(adlibemu_context *ctx, unsigned char *sndptr, long numbytes)
+{
+    adlibgetsample_scope(ctx, sndptr, numbytes, 0);
+}
+
+void adlibgetsample_scope(adlibemu_context *ctx, unsigned char *sndptr, long numbytes, short *scope_buf)
 {
     long i, j, k=0, ns, endsamples, rptrs, numsamples;
     celltype *cptr;
@@ -554,6 +559,14 @@ void adlibgetsample (adlibemu_context *ctx, unsigned char *sndptr, long numbytes
 	    }
 	}
 
+	if (scope_buf) {
+	    for (j=0; j<9; j++) {
+		for (i=0; i<endsamples; i++) {
+		    clipit16(nrptr[j][i]*AMPSCALE, &scope_buf[j * numsamples + ns + i]);
+		}
+	    }
+	}
+
 	if (numspeakers == 1)
 	{
 	    if (bytespersample == 1)
diff --git a/src/adlibemu.h b/src/adlibemu.h
