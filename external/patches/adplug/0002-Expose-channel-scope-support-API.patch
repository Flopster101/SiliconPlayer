+void CEmuopl::update_and_scope(short *buf, int samples, short *scope_buf)
 {
   int i;
 
@@ -78,7 +83,7 @@ void CEmuopl::update(short *buf, int samples)
   case TYPE_OPL2:
     //for opl2 mode:
     //render chip0 to the output buffer
-    YM3812UpdateOne(opl[0],outbuf,samples);
+    YM3812UpdateOne(opl[0],outbuf,samples,scope_buf,0);
 
     //if we are supposed to output stereo,
     //then we need to dup the mono channel
@@ -95,8 +100,8 @@ void CEmuopl::update(short *buf, int samples)
   case TYPE_DUAL_OPL2:
     //for dual opl2 mode:
     //render each chip to a different tempbuffer
-    YM3812UpdateOne(opl[0],tempbuf2,samples);
-    YM3812UpdateOne(opl[1],tempbuf,samples);
+    YM3812UpdateOne(opl[0],tempbuf2,samples,scope_buf,0);
+    YM3812UpdateOne(opl[1],tempbuf,samples,scope_buf,9);
 
     //output stereo:
     //then we need to interleave the two buffers
