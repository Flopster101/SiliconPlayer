+void CKemuopl::update_and_scope(short *buf, int samples, short *scope_buf)
 {
   int i;
   //ensure that our mix buffers are adequately sized
@@ -34,8 +39,8 @@ void CKemuopl::update(short *buf, int samples)
   short *outbuf = use16bit ? buf : mixbuf2;
 
   //render each chip to a different tempbuffer
-  adlibgetsample(&ctx[0], (unsigned char *)mixbuf0, samples * 2 /* 16-bit */);
-  adlibgetsample(&ctx[1], (unsigned char *)mixbuf1, samples * 2 /* 16-bit */);
+  adlibgetsample_scope(&ctx[0], (unsigned char *)mixbuf0, samples * 2 /* 16-bit */, scope_buf);
+  adlibgetsample_scope(&ctx[1], (unsigned char *)mixbuf1, samples * 2 /* 16-bit */, scope_buf ? scope_buf + 9 * samples : 0);
 
   //output stereo:
   //then we need to interleave the two buffers
