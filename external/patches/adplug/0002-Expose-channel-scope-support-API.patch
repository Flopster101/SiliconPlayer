diff --git a/src/fmopl.c b/src/fmopl.c
index b81ba05..ce5b711 100644
--- a/src/fmopl.c
+++ b/src/fmopl.c
@@ -1018,7 +1018,7 @@ static void OPLWriteReg(FM_OPL *OPL, int r, int v)
 /*******************************************************************************/
 
 /* ---------- update one of chip ----------- */
-void YM3812UpdateOne(FM_OPL *OPL, INT16 *buffer, int length)
+void YM3812UpdateOne(FM_OPL *OPL, INT16 *buffer, int length, INT16 *scope_buf, int scope_offset)
 {
 	int i;
 	int data;
@@ -1037,11 +1037,27 @@ void YM3812UpdateOne(FM_OPL *OPL, INT16 *buffer, int length)
 		OPL->vib = OPL->vib_table[(vibCnt+=OPL->vibIncr)>>VIB_SHIFT];
 		OPL->outd[0] = 0;
 		/* FM part */
-		for(CH=OPL->P_CH ; CH < R_CH ; CH++)
+		for(CH=OPL->P_CH ; CH < R_CH ; CH++) {
+			int pre = OPL->outd[0];
 			OPL_CALC_CH(OPL, CH);
+			if (scope_buf) {
+				int ch_idx = scope_offset + (CH - OPL->P_CH);
+				scope_buf[ch_idx * length + i] = Limit(OPL->outd[0] - pre, OPL_MAXOUT, OPL_MINOUT) >> OPL_OUTSB;
+			}
+		}
 		/* Rythm part */
-		if(rhythm)
+		if(rhythm) {
+			int pre = OPL->outd[0];
 			OPL_CALC_RH(OPL, OPL->P_CH);
+			if (scope_buf) {
+				// Rhythm part calculates channels 6, 7, 8 together
+				// We just distribute the rhythm mix to channel 6 for visualization purposes, or split them?
+				// Actually, we can just dump the total rhythm delta into channel 6.
+				int ch_idx = scope_offset + 6;
+				scope_buf[ch_idx * length + i] = Limit(OPL->outd[0] - pre, OPL_MAXOUT, OPL_MINOUT) >> OPL_OUTSB;
+				// channels 7 and 8 remain 0
+			}
+		}
 		/* limit check */
 		data = Limit( OPL->outd[0] , OPL_MAXOUT, OPL_MINOUT );
 		/* store to sound buffer */
