+++ b/src/nukedopl.c
@@ -1174,6 +1174,7 @@ inline void OPL3_Generate4Ch(opl3_chip *chip, int16_t *buf4)
         channel = &chip->channel[ii];
         out = channel->out;
         accm = *out[0] + *out[1] + *out[2] + *out[3];
+        chip->samples_scope[ii] = OPL3_ClipSample(accm);
 #if OPL_ENABLE_STEREOEXT
         mix[0] += (int16_t)((accm * channel->rightpan) >> 16);
 #else
@@ -1273,6 +1274,9 @@ void OPL3_Generate4ChResampled(opl3_chip *chip, int16_t *buf4)
         chip->oldsamples[1] = chip->samples[1];
         chip->oldsamples[2] = chip->samples[2];
         chip->oldsamples[3] = chip->samples[3];
+        for (int i = 0; i < 18; i++) {
+            chip->oldsamples_scope[i] = chip->samples_scope[i];
+        }
         OPL3_Generate4Ch(chip, chip->samples);
         chip->samplecnt -= chip->rateratio;
     }
@@ -1284,6 +1288,12 @@ void OPL3_Generate4ChResampled(opl3_chip *chip, int16_t *buf4)
                         + chip->samples[2] * chip->samplecnt) / chip->rateratio);
     buf4[3] = (int16_t)((chip->oldsamples[3] * (chip->rateratio - chip->samplecnt)
                         + chip->samples[3] * chip->samplecnt) / chip->rateratio);
+    if (chip->scope_buf) {
+        for (int i = 0; i < 18; i++) {
+            chip->scope_buf[i] = (int16_t)((chip->oldsamples_scope[i] * (chip->rateratio - chip->samplecnt)
+                                + chip->samples_scope[i] * chip->samplecnt) / chip->rateratio);
+        }
+    }
     chip->samplecnt += 1 << RSM_FRAC;
 }
 
@@ -1520,6 +1530,9 @@ void OPL3_Generate4ChStream(opl3_chip *chip, int16_t *sndptr1, int16_t *sndptr2,
         sndptr2[1] = samples[3];
         sndptr1 += 2;
         sndptr2 += 2;
+        if (chip->scope_buf) {
+            chip->scope_buf += 18;
+        }
     }
 }
 
@@ -1531,5 +1544,8 @@ void OPL3_GenerateStream(opl3_chip *chip, int16_t *sndptr, uint32_t numsamples)
     {
         OPL3_GenerateResampled(chip, sndptr);
         sndptr += 2;
+        if (chip->scope_buf) {
+            chip->scope_buf += 18;
+        }
     }
 }
