+  ht->ht_ChannelPatternFx1Param[channel] = Step->stp_FXParam;
+  ht->ht_ChannelPatternFx2[channel] = hvl_has_visible_effect( Step->stp_FXb & 0x0f, Step->stp_FXbParam ) ? (int8) ( Step->stp_FXb & 0x0f ) : (int8) -1;
+  ht->ht_ChannelPatternFx2Param[channel] = Step->stp_FXbParam;
   
   // --------- 1.6: from here --------------
 
@@ -1710,9 +1757,12 @@ void hvl_mixchunk( struct hvl_tune *ht, uint32 samples, int8 *buf1, int8 *buf2,
   int32   panr[MAX_CHANNELS];
 //  uint32  vu[MAX_CHANNELS];
   int32   a=0, b=0, j;
