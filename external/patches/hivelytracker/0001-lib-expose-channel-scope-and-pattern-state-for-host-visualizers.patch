     loops--;
   } while( loops );
 }
+
+int hvl_GetChannelScopeSamples( const struct hvl_tune *ht, float *scope, int samples_per_channel, int n_channels )
+{
+  int available, channels, padding, channel, sample;
+  uint32 start;
+  float *dst;
+
+  if( !ht || !scope || samples_per_channel <= 0 || n_channels <= 0 )
+    return 0;
+
+  channels = ht->ht_Channels;
+  if( channels > MAX_CHANNELS ) channels = MAX_CHANNELS;
+  if( channels > n_channels ) channels = n_channels;
+  if( channels <= 0 ) return 0;
+
+  available = samples_per_channel;
+  if( available > HVL_CHANNEL_SCOPE_HISTORY_SAMPLES )
+    available = HVL_CHANNEL_SCOPE_HISTORY_SAMPLES;
+  padding = samples_per_channel - available;
+  start = ( ht->ht_ChannelScopeWritePos + HVL_CHANNEL_SCOPE_HISTORY_SAMPLES - available ) & (HVL_CHANNEL_SCOPE_HISTORY_SAMPLES - 1);
+
+  for( channel = 0; channel < channels; ++channel )
+  {
+    dst = scope + ( channel * samples_per_channel );
+    if( padding > 0 )
+      memset( dst, 0, (size_t) padding * sizeof( float ) );
+    for( sample = 0; sample < available; ++sample )
+      dst[padding + sample] = ht->ht_ChannelScopeHistory[(channel * HVL_CHANNEL_SCOPE_HISTORY_SAMPLES) + ((start + sample) & (HVL_CHANNEL_SCOPE_HISTORY_SAMPLES - 1))];
+  }
+
+  return channels;
+}
+
+int hvl_GetChannelPatternState( const struct hvl_tune *ht, int *state, int stride, int n_channels )
+{
+  int channels, channel, note, instrument, fx1, fx2, active;
+
+  if( !ht || !state || stride < 8 || n_channels <= 0 )
+    return 0;
+
+  channels = ht->ht_Channels;
+  if( channels > MAX_CHANNELS ) channels = MAX_CHANNELS;
+  if( channels > n_channels ) channels = n_channels;
+  if( channels <= 0 ) return 0;
+
+  for( channel = 0; channel < channels; ++channel )
+  {
+    note = ht->ht_ChannelPatternNote[channel];
+    if( !note )
+      note = ht->ht_Voices[channel].vc_TrackPeriod;
+    instrument = ht->ht_ChannelPatternInstrument[channel];
+    if( instrument <= 0 )
+      instrument = hvl_resolve_active_instrument_index( ht, &ht->ht_Voices[channel] );
+    fx1 = ht->ht_ChannelPatternFx1[channel];
+    fx2 = ht->ht_ChannelPatternFx2[channel];
+    active = ( ht->ht_Voices[channel].vc_TrackOn != 0 ) &&
+      ( ht->ht_Voices[channel].vc_VoiceVolume > 0 || note > 0 || instrument > 0 || fx1 >= 0 || fx2 >= 0 );
+
+    state[(channel * stride) + 0] = note > 0 ? note : -1;
+    state[(channel * stride) + 1] = ht->ht_Voices[channel].vc_VoiceVolume;
+    state[(channel * stride) + 2] = fx1;
+    state[(channel * stride) + 3] = fx1 >= 0 ? ht->ht_ChannelPatternFx1Param[channel] : -1;
+    state[(channel * stride) + 4] = fx2;
+    state[(channel * stride) + 5] = fx2 >= 0 ? ht->ht_ChannelPatternFx2Param[channel] : -1;
+    state[(channel * stride) + 6] = instrument > 0 ? instrument : -1;
+    state[(channel * stride) + 7] = active;
+  }
+
+  return channels;
+}
