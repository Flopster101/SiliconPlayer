 //        if( abs( j ) > vu[i] ) vu[i] = abs( j );
 
@@ -1772,6 +1827,7 @@ void hvl_mixchunk( struct hvl_tune *ht, uint32 samples, int8 *buf1, int8 *buf2,
         b += (j * panr[i]) >> 7;
         pos[i] += delta[i];
       }
+      scope_write_pos = (scope_write_pos + 1) & (HVL_CHANNEL_SCOPE_HISTORY_SAMPLES - 1);
       
       a = (a*ht->ht_mixgain)>>8;
       b = (b*ht->ht_mixgain)>>8;
@@ -1797,6 +1853,7 @@ void hvl_mixchunk( struct hvl_tune *ht, uint32 samples, int8 *buf1, int8 *buf2,
     ht->ht_Voices[i].vc_RingSamplePos = rpos[i];
 //    ht->ht_Voices[i].vc_VUMeter = vu[i];
