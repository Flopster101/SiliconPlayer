@@ -23,6 +24,37 @@
 ** Waves
 */
 
+static void hvl_reset_channel_visual_state( struct hvl_tune *ht )
+{
+  ht->ht_ChannelScopeWritePos = 0;
+  memset( ht->ht_ChannelScopeHistory, 0, sizeof( ht->ht_ChannelScopeHistory ) );
+  memset( ht->ht_ChannelPatternNote, 0, sizeof( ht->ht_ChannelPatternNote ) );
+  memset( ht->ht_ChannelPatternInstrument, 0, sizeof( ht->ht_ChannelPatternInstrument ) );
+  memset( ht->ht_ChannelPatternFx1, 0xff, sizeof( ht->ht_ChannelPatternFx1 ) );
+  memset( ht->ht_ChannelPatternFx1Param, 0, sizeof( ht->ht_ChannelPatternFx1Param ) );
+  memset( ht->ht_ChannelPatternFx2, 0xff, sizeof( ht->ht_ChannelPatternFx2 ) );
+  memset( ht->ht_ChannelPatternFx2Param, 0, sizeof( ht->ht_ChannelPatternFx2Param ) );
+}
+
+static int hvl_has_visible_effect( uint8 fx, uint8 param )
+{
+  return fx != 0 || param != 0;
+}
+
+static int hvl_resolve_active_instrument_index( const struct hvl_tune *ht, const struct hvl_voice *voice )
+{
+  ptrdiff_t index;
+
+  if( !ht || !voice || !voice->vc_Instrument || !ht->ht_Instruments )
+    return 0;
+
+  index = voice->vc_Instrument - ht->ht_Instruments;
+  if( index < 1 || index > ht->ht_InstrumentNr )
+    return 0;
+
+  return (int) index;
+}
+
 void hvl_reset_some_stuff( struct hvl_tune *ht )
 {
   uint32 i;
@@ -62,6 +94,8 @@ void hvl_reset_some_stuff( struct hvl_tune *ht )
     ht->ht_Voices[i].vc_TrackOn           = 1;
     ht->ht_Voices[i].vc_MixSource         = ht->ht_Voices[i].vc_VoiceBuffer;
   }
