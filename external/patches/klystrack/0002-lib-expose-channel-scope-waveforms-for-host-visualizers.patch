+KLYSAPI int KSND_GetChannelScopeSamples(KPlayer *player, float *scope, int samples_per_channel, int n_channels)
+{
+	if (player == NULL || scope == NULL || samples_per_channel <= 0)
+		return 0;
+	if (player->cyd.scope_buffer == NULL || player->cyd.scope_buffer_samples <= 0)
+		return 0;
+
+	const int available_channels = player->mus.song != NULL ? player->mus.song->num_channels : player->cyd.n_channels;
+	const int channels = my_min(my_min(available_channels, player->cyd.n_channels), n_channels);
+	if (channels <= 0)
+		return 0;
+
+	const int copied_samples = my_min(samples_per_channel, player->cyd.scope_buffer_samples);
+	const int pad_offset = samples_per_channel - copied_samples;
+	memset(scope, 0, sizeof(*scope) * (size_t) samples_per_channel * (size_t) channels);
+
+	cyd_lock(&player->cyd, 1);
+	const int start =
+			(player->cyd.scope_write_position - copied_samples + player->cyd.scope_buffer_samples) %
+			player->cyd.scope_buffer_samples;
+	for (int channel = 0; channel < channels; ++channel)
+	{
+		const float *channel_scope = player->cyd.scope_buffer + (size_t) channel * (size_t) player->cyd.scope_buffer_samples;
+		float *dest = scope + (size_t) channel * (size_t) samples_per_channel;
+		for (int i = 0; i < copied_samples; ++i)
+		{
+			const int source_index = (start + i) % player->cyd.scope_buffer_samples;
+			dest[pad_offset + i] = channel_scope[source_index];
+		}
+	}
+	cyd_lock(&player->cyd, 0);
+
+	return channels;
+}
 
 
