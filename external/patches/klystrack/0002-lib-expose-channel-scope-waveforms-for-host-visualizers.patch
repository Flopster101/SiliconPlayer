+
+static inline float cyd_scope_normalize_sample(Sint32 sample)
+{
+	const float scaled = (float) sample / (32768.0f * PRE_GAIN_DIVISOR);
+	if (scaled < -1.0f) return -1.0f;
+	if (scaled > 1.0f) return 1.0f;
+	return scaled;
+}
+
+static inline void cyd_capture_scope_sample(CydEngine *cyd, int channel, Sint32 sample)
+{
+	if (cyd == NULL || cyd->scope_buffer == NULL || cyd->scope_buffer_samples <= 0)
+		return;
+	if (channel < 0 || channel >= CYD_MAX_CHANNELS)
+		return;
+
+	const size_t offset = (size_t) channel * (size_t) cyd->scope_buffer_samples + (size_t) cyd->scope_write_position;
+	cyd->scope_buffer[offset] = cyd_scope_normalize_sample(sample);
+}
+
+void cyd_clear_scope_buffer(CydEngine *cyd)
+{
+	if (cyd == NULL || cyd->scope_buffer == NULL || cyd->scope_buffer_samples <= 0)
+		return;
+
+	memset(cyd->scope_buffer, 0, sizeof(*cyd->scope_buffer) * (size_t) CYD_MAX_CHANNELS * (size_t) cyd->scope_buffer_samples);
+	cyd->scope_write_position = 0;
+}
+
