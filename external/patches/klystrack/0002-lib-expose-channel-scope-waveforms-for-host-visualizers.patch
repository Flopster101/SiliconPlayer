+/**
+ * Copy recent per-channel waveform history into a host-provided buffer.
+ *
+ * Samples are returned oldest-to-newest for each channel, flattened channel-major:
+ * `[ch0 samples][ch1 samples]...`
+ *
+ * @param player player context which is currently playing a song set with KSND_PlaySong()
+ * @param[out] scope destination float buffer sized for @c samples_per_channel * @c n_channels
+ * @param samples_per_channel requested history length per channel
+ * @param n_channels maximum number of channels to copy
+ * @return number of channels written
+ */
+KLYSAPI extern int KSND_GetChannelScopeSamples(
+	KPlayer *player,
+	float *scope,
+	int samples_per_channel,
+	int n_channels
+);
 
 #ifdef __cplusplus
