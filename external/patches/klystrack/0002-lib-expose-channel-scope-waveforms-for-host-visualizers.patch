 src/lib/ksnd.h |  33 +++++++++++---
 src/snd/cyd.c  | 139 +++++++++++++++++++++++++++++++++++++++------------------
 src/snd/cyd.h  |  35 ++++++++-------
 4 files changed, 198 insertions(+), 86 deletions(-)

