 #ifdef GEN_TYPES_H
 #include "gen_types.h" /* same as gme_types.h but generated by build system */
@@ -423,6 +424,50 @@ void      gme_enable_accuracy( Music_Emu* me, int enabled )         { me->enable
 void      gme_clear_playlist ( Music_Emu* me )                      { me->clear_playlist(); }
 int       gme_type_multitrack( gme_type_t t )                       { return t->track_count != 1; }
 int       gme_multi_channel  ( Music_Emu const* me )                { return me->multi_channel(); }
+int       gme_nsf_has_vrc6   ( Music_Emu const* me )
+{
+	if ( !me )
+		return 0;
+
+	const gme_type_t type = me->type();
+	if ( type != gme_nsf_type && type != gme_nsfe_type )
+		return 0;
+
+	return STATIC_CAST(Nsf_Emu const*, me)->has_vrc6() ? 1 : 0;
+}
+void gme_set_nsf_vrc6_scope_mute_mask( Music_Emu* me, int mask )
+{
+	if ( !me )
+		return;
+
+	const gme_type_t type = me->type();
+	if ( type != gme_nsf_type && type != gme_nsfe_type )
+		return;
+
+	STATIC_CAST(Nsf_Emu*, me)->set_vrc6_scope_mute_mask_( mask );
+}
+gme_err_t gme_play_nsf_vrc6_scope( Music_Emu* me, int frame_count, short out [] )
+{
+	if ( !me )
+		return "Invalid emulator";
+
+	const gme_type_t type = me->type();
+	if ( type != gme_nsf_type && type != gme_nsfe_type )
+		return "NSF VRC6 scope unavailable";
+
+	return STATIC_CAST(Nsf_Emu*, me)->play_vrc6_scope_( frame_count, out );
+}
+void gme_clear_nsf_vrc6_scope( Music_Emu* me )
+{
+	if ( !me )
+		return;
+
+	const gme_type_t type = me->type();
+	if ( type != gme_nsf_type && type != gme_nsfe_type )
+		return;
+
+	STATIC_CAST(Nsf_Emu*, me)->clear_vrc6_scope_();
+}
 
 void      gme_set_equalizer  ( Music_Emu* me, gme_equalizer_t const* eq )
 {
